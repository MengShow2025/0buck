{
  "redirects": [
    {
      "source": "/test-redirect",
      "destination": "https://zerobuck-api.onrender.com/api/v1/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/:match*",
      "destination": "https://zerobuck-api.onrender.com/api/:match*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
