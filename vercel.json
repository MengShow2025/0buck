{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://zerobuck-api.onrender.com/api/$1"
    },
    {
      "source": "/v1/(.*)",
      "destination": "https://zerobuck-api.onrender.com/api/v1/$1"
    },
    {
      "source": "/auth/bind(.*)",
      "destination": "https://zerobuck-api.onrender.com/auth/bind$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
