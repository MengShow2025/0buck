{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://www.0buck.com/api/$1"
    },
    {
      "source": "/v1/(.*)",
      "destination": "https://www.0buck.com/api/v1/$1"
    },
    {
      "source": "/healthz",
      "destination": "https://www.0buck.com/healthz"
    },
    {
      "source": "/(.*)",
      "destination": "https://www.0buck.com/$1"
    }
  ]
}
