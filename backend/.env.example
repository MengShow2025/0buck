# Project Configuration
PROJECT_NAME="0Buck Backend"
API_V1_STR="/api/v1"

# Database (PostgreSQL)
# DATABASE_URL="postgresql://user:password@localhost/0buck"
POSTGRES_SERVER="localhost"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="password"
POSTGRES_DB="0buck"

# Alibaba / 1688 (Supply Library)
ALIBABA_1688_API_KEY=""
ALIBABA_1688_API_URL="https://api.1688.com"

# Shopify
# Get from Shopify Admin > Settings > Apps and sales channels > Develop apps
SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""
SHOPIFY_SHOP_NAME="0buck-shop"
SHOPIFY_ACCESS_TOKEN=""
SHOPIFY_STOREFRONT_TOKEN=""

# AI (Google Gemini / LangGraph)
# NEVER commit the real key here!
GOOGLE_API_KEY=""
EXA_API_KEY=""
QDRANT_HOST="localhost"
QDRANT_PORT=6333

# IM Gateway (v5.6)
WHATSAPP_API_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_VERIFY_TOKEN="0buck_verify_token"

FEISHU_APP_ID=""
FEISHU_APP_SECRET=""
FEISHU_VERIFY_TOKEN=""
FEISHU_ENCRYPT_KEY=""

TELEGRAM_BOT_TOKEN=""
DISCORD_BOT_TOKEN=""
DISCORD_CLIENT_ID=""
IM_GATEWAY_ENABLE_CELERY="false"

# Domains & Routing
BACKEND_URL="http://localhost:8000"
FRONTEND_URL="http://localhost:5173"
STOREFRONT_DOMAIN="0buck.com"
SHOPIFY_CHECKOUT_DOMAIN="shop.0buck.com"

# OAuth (Google / Apple / Facebook)
# Callback base is: ${BACKEND_URL}/api/v1/auth/callback/{provider}
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# Security / Session
ENVIRONMENT="development"
COOKIE_DOMAIN=""
SECRET_KEY=""
ALLOWED_ORIGINS="http://localhost:5173,https://www.0buck.com"

# Pricing & Currency
EXCHANGE_RATE=0.14
EXCHANGE_BUFFER=0.005
